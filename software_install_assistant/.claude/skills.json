{
  "skills": [
    {
      "name": "auto_fix",
      "description": "自动检测并修复后端服务（数据库、缓存、消息队列、搜索引擎）的协同配置问题",
      "version": "1.0.0",
      "author": "AI Assistant",
      "commands": [
        {
          "name": "auto_fix",
          "description": "检测并自动修复后端服务问题",
          "parameters": {
            "type": "object",
            "properties": {
              "service": {
                "type": "string",
                "description": "指定要检测的服务 (mysql, postgres, mongodb, redis, rabbitmq, kafka, elasticsearch, configuration, all)",
                "enum": ["mysql", "postgres", "mongodb", "redis", "rabbitmq", "kafka", "elasticsearch", "configuration", "all"],
                "default": "all"
              },
              "dry_run": {
                "type": "boolean",
                "description": "只检测不修复",
                "default": false
              },
              "force": {
                "type": "boolean",
                "description": "强制执行修复（跳过确认）",
                "default": false
              }
            },
            "required": []
          }
        }
      ],
      "examples": [
        "/claude auto_fix",
        "/claude auto_fix --service mysql",
        "/claude auto_fix --service configuration",
        "/claude auto_fix --service redis --dry-run",
        "/claude auto_fix --service all --force"
      ]
    },
    {
      "name": "ocr",
      "description": "识别图片中的错误信息，自动分类问题类型并提供解决建议",
      "version": "1.0.0",
      "author": "AI Assistant",
      "commands": [
        {
          "name": "ocr",
          "description": "识别图片中的错误信息",
          "parameters": {
            "type": "object",
            "properties": {
              "file": {
                "type": "string",
                "description": "图片文件路径"
              },
              "base64": {
                "type": "string",
                "description": "Base64 编码的图片数据"
              }
            },
            "required": []
          }
        }
      ],
      "examples": [
        "/claude ocr --file ./error_screenshot.png",
        "直接在对话中粘贴图片进行识别"
      ],
      "note": "需要安装 Tesseract OCR 引擎: https://github.com/UB-Mannheim/tesseract/wiki"
    }
  ]
}
