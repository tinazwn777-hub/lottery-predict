# Application
APP_NAME=Course Summary Generator
APP_VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Storage
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
MAX_FILE_SIZE=52428800

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Celery (using in-memory for simplicity in MVP)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_URL=redis://localhost:6379/0

# Web Scraping
REQUEST_TIMEOUT=30
MAX_RETRY=3

# Image
DEFAULT_IMAGE_WIDTH=1200
DEFAULT_IMAGE_HEIGHT=1600

# Screenshot API (hcti.io / htmlcsstoimage.com)
# 注册: https://hcti.io
# 免费额度: 100 张图片/月
HCTI_API_KEY=019c6cf6-9243-7610-a150-6d024a3b3f78
HCTI_API_ID=01KHPFD4J3TGBEN51ZNNV45NSW

# Screenshot API (APIFlash - 备用)
# 注册: https://apiflash.com
# 免费额度: 100 张图片/月
APIFLASH_API_KEY=your_api_key_here
