# Application
APP_NAME=Course Summary Generator
APP_VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Storage
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
MAX_FILE_SIZE=52428800

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Celery (using in-memory for simplicity in MVP)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_URL=redis://localhost:6379/0

# Web Scraping
REQUEST_TIMEOUT=30
MAX_RETRY=3

# Image
DEFAULT_IMAGE_WIDTH=1200
DEFAULT_IMAGE_HEIGHT=1600
